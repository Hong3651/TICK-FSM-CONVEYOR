# === 이 프로젝트 전용 ===
# 로그 (Day 7에 생길 수 있는 실행 로그)
*.log
log.txt

# 에디터/OS 부산물
.vscode/
Thumbs.db

# === 표준 C .gitignore (컴파일 결과물은 소스에서 다시 만들 수 있어 저장 안 함) ===
# Prerequisites
*.d

# Object files
*.o
*.ko
*.obj
*.elf

# Linker output
*.ilk
*.map
*.exp

# Precompiled Headers
*.gch
*.pch

# Libraries
*.lib
*.a
*.la
*.lo

# Shared objects (inc. Windows DLLs)
*.dll
*.so
*.so.*
*.dylib

# Executables
*.exe
*.out
*.app
*.i*86
*.x86_64
*.hex

# Debug files
*.dSYM/
*.su
*.idb
*.pdb

# Kernel Module Compile Results
*.mod*
*.cmd
.tmp_versions/
modules.order
Module.symvers
Mkfile.old
dkms.conf

# debug information files
*.dwo
